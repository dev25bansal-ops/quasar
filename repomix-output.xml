            buildConfigurationList = __BCL__;
            mainGroup = __MG__;
            productRefGroup = __MG__;
            projectDirPath = "";
            targets = ();
        }};
        __BCL__ = {{
            isa = XCConfigurationList;
            buildConfigurations = ( __BC__ );
